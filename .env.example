HOSTING_ROOT=/media/ssdmount/websites-v2
BACKUPS_DIR=/media/ssdmount/websites-v2/backups
EXPORTS_DIR=/media/ssdmount/websites-v2/backups/exports

UI_ADMIN_EMAIL=panel-admin@example.com
UI_ADMIN_PASSWORD=replace-with-a-unique-long-panel-password
# Optional stable encryption key. If empty, the panel generates one in its data volume.
UI_SETTINGS_KEY=
# Maximum completed/failed job records retained by the panel.
JOB_HISTORY_LIMIT=250

# Nginx Proxy Manager administrator. On an empty NPM database these values
# create the first administrator; the panel then uses the same API account.
NPM_API_URL=http://hosting-npm:81/api
NPM_IDENTITY=npm-admin@example.com
NPM_SECRET=replace-with-a-unique-long-npm-password
ACME_EMAIL=admin@example.com

# File Browser first administrator. Applied only when filebrowser.db is absent.
FILEBROWSER_ADMIN_USERNAME=file-admin
FILEBROWSER_ADMIN_PASSWORD=replace-with-a-unique-long-filebrowser-password

# API token permissions: Zone:Read and DNS:Edit for the managed zones.
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-token
# Use a separate least-privilege token with zone read and Rulesets/WAF write.
# Cloudflare permission labels vary between user-owned and account-owned tokens.
CLOUDFLARE_SECURITY_API_TOKEN=replace-with-cloudflare-security-token
CLOUDFLARE_ACCOUNT_ID=replace-with-32-character-account-id

MYSQL_SITE_PREFIX=yogali00_

# Persistent database credentials. Generate unique values before first start.
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-password
NPM_DB_USER=npm_db
NPM_DB_PASSWORD=replace-with-a-long-random-password
NPM_DB_NAME=npm_db
